PORT=3000
CRM_BASE_PATH=/employeelogin

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=sthill_crm
# Optional: use unix socket instead of host/port (recommended on some shared hosts).
# MYSQL_SOCKET_PATH=/var/lib/mysql/mysql.sock
MYSQL_SSL=false
# Optional when MYSQL_SSL=true and provider requires CA cert.
MYSQL_SSL_CA_BASE64=

# One-time import source for SQLite -> MySQL migration.
SQLITE_SOURCE_PATH=./crm.db

# Set to true only if you explicitly want self-service account creation.
ALLOW_SIGNUP=false

# Required in production. Use a long random secret.
JWT_SECRET=replace-with-a-long-random-secret

# Initial admin user (seeded only when users table is empty).
CRM_ADMIN_NAME=
CRM_ADMIN_EMAIL=
CRM_ADMIN_PASSWORD=

# Optional AI key for call assistant features.
GEMINI_API_KEY=

# No Supabase variables are required in this combined build.

# Twilio Voice (browser dialer)
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_AUTH_TOKEN=
TWILIO_TWIML_APP_SID=
TWILIO_CALLER_ID=
TWILIO_PUBLIC_BASE_URL=https://sthillstudios.com/employeelogin/api
TWILIO_VALIDATE_SIGNATURE=true
TWILIO_ACCESS_TOKEN_TTL_SECONDS=3600
