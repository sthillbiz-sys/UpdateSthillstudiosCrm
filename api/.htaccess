Options -MultiViews
DirectoryIndex index.php

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /employeelogin/api/

  # Pass existing files/folders directly.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Route clean URLs (e.g., /api/auth/login) to index.php.
  RewriteRule ^(.*)$ index.php?route=$1 [QSA,L]
</IfModule>

